<?xml version="1.0"?>
<labwc_config>
  <keyboard>
    <!-- Allow quitting the Wayland compositor with Ctrl+Alt+Backspace -->
    <!-- equivalent to: setxkbmap -option terminate:ctrl_alt_bksp -->
    <keybind key="C-A-BackSpace">
      <action name="Exit" />
    </keybind>
  </keyboard>
</labwc_config>
